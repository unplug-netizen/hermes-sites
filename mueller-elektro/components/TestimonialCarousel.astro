---
export interface Props {
  title: string;
  items: Array<{
    name: string;
    location: string;
    rating: number;
    text: string;
  }>;
}

const { title, items } = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {items.map((item) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class={`w-5 h-5 ${i < item.rating ? 'text-amber-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <div class="relative mb-4">
            <svg class="absolute -top-2 -left-1 w-8 h-8 text-primary-100" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p class="text-gray-700 text-sm md:text-base leading-relaxed relative z-10 pl-6">{item.text}</p>
          </div>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-sm">
              {item.name.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-bold text-gray-900">{item.name}</div>
              <div class="text-xs text-gray-500">{item.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
