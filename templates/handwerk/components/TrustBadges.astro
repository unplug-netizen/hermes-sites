---
export interface Props {
  title: string;
  badges: Array<{
    icon: string;
    label: string;
    sublabel: string;
  }>;
}

const { title, badges } = Astro.props;
---

<section class="py-14 md:py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 mb-3">{title}</h2>
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6">
      {badges.map((badge) => (
        <div class="bg-white rounded-xl p-5 md:p-6 text-center shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="text-3xl md:text-4xl mb-3">{badge.icon}</div>
          <div class="text-sm md:text-base font-bold text-gray-900">{badge.label}</div>
          <div class="text-xs md:text-sm text-gray-500 mt-1">{badge.sublabel}</div>
        </div>
      ))}
    </div>
  </div>
</section>
