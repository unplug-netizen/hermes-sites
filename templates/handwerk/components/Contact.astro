---
export interface Props {
  title: string;
  address: string;
  phone: string;
  hours: string;
}

const { title, address, phone, hours } = Astro.props;
---

<section id="kontakt" class="py-20 bg-slate-900 text-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
      <div class="w-24 h-1 bg-blue-500 mx-auto rounded-full"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8 text-center">
      <div class="p-6">
        <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Adresse</h3>
        <p class="text-slate-300">{address}</p>
      </div>
      
      <div class="p-6">
        <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Telefon</h3>
        <a href={`tel:${phone}`} class="text-blue-500 hover:text-blue-400 transition-colors">{phone}</a>
      </div>
      
      <div class="p-6">
        <div class="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Öffnungszeiten</h3>
        <p class="text-slate-300">{hours}</p>
      </div>
    </div>
    
    <div class="mt-16 text-center">
      <a href={`tel:${phone}`} class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold px-10 py-5 rounded-lg text-xl transition-all transform hover:scale-105 shadow-lg">
        📞 Jetzt anfragen
      </a>
      <p class="mt-4 text-slate-400">Kostenlose Beratung vor Ort!</p>
    </div>
  </div>
</section>