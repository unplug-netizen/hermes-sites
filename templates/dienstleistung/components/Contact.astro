---
export interface Props {
  title: string;
  address: string;
  phone: string;
  hours: string;
  email?: string;
}

const { title, address, phone, hours, email } = Astro.props;
---

<section id="kontakt" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      <div class="bg-slate-50 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Adresse</h3>
        <p class="text-gray-600 text-sm leading-relaxed">{address}</p>
      </div>

      <div class="bg-slate-50 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Telefon</h3>
        <a href={`tel:${phone}`} class="text-primary-600 hover:text-primary-700 font-semibold text-sm transition-colors">{phone}</a>
      </div>

      <div class="bg-slate-50 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">E-Mail</h3>
        {email ? (
          <a href={`mailto:${email}`} class="text-primary-600 hover:text-primary-700 font-semibold text-sm transition-colors">{email}</a>
        ) : (
          <p class="text-gray-600 text-sm">info@beispiel-beratung.de</p>
        )}
      </div>

      <div class="bg-slate-50 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Öffnungszeiten</h3>
        <p class="text-gray-600 text-sm leading-relaxed">{hours}</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 md:mt-16 text-center">
      <a href={`tel:${phone}`} class="inline-flex items-center gap-3 bg-primary-600 hover:bg-primary-700 text-white font-bold px-8 py-4 rounded-lg text-lg transition-all transform hover:scale-105 shadow-lg shadow-primary-600/25">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Jetzt anrufen: {phone}
      </a>
      <p class="mt-4 text-gray-500 text-sm">Kostenloses Erstgespräch – wir freuen uns auf Sie!</p>
    </div>
  </div>
</section>
