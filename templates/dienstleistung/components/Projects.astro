---
export interface Props {
  title: string;
  subtitle?: string;
  projects: Array<{
    title: string;
    description: string;
    before_image: string;
    after_image: string;
  }>;
}

const { title, subtitle, projects } = Astro.props;
---

<section id="projekte" class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{title}</h2>
      {subtitle && <p class="text-gray-600 text-lg max-w-2xl mx-auto">{subtitle}</p>}
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full mt-4"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-10">
      {projects.map((project) => (
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
          <div class="relative group">
            <div class="grid grid-cols-2 gap-0">
              <div class="relative overflow-hidden">
                <img src={project.before_image} alt="Vorher" class="w-full h-52 md:h-64 object-cover" loading="lazy" />
                <div class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-md shadow-sm">
                  VORHER
                </div>
              </div>
              <div class="relative overflow-hidden">
                <img src={project.after_image} alt="Nachher" class="w-full h-52 md:h-64 object-cover" loading="lazy" />
                <div class="absolute top-3 right-3 bg-green-500 text-white text-xs font-bold px-3 py-1.5 rounded-md shadow-sm">
                  NACHHER
                </div>
              </div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          </div>
          <div class="p-5 md:p-6">
            <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2">{project.title}</h3>
            <p class="text-gray-600 text-sm md:text-base">{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
