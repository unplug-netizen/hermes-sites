---
export interface Props {
  title: string;
  text: string;
  image: string;
}

const { title, text, image } = Astro.props;
---

<section id="ueber-uns" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
      <div class="order-2 md:order-1">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 leading-tight">{title}</h2>
        <div class="prose prose-lg text-gray-600 leading-relaxed">
          <p>{text}</p>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-3 md:gap-4">
          <div class="text-center p-3 md:p-4 bg-primary-50 rounded-xl">
            <div class="text-2xl md:text-3xl font-extrabold text-primary-600">20+</div>
            <div class="text-xs md:text-sm text-gray-600 mt-1">Jahre Erfahrung</div>
          </div>
          <div class="text-center p-3 md:p-4 bg-primary-50 rounded-xl">
            <div class="text-2xl md:text-3xl font-extrabold text-primary-600">500+</div>
            <div class="text-xs md:text-sm text-gray-600 mt-1">Mandanten</div>
          </div>
          <div class="text-center p-3 md:p-4 bg-primary-50 rounded-xl">
            <div class="text-2xl md:text-3xl font-extrabold text-primary-600">4.8★</div>
            <div class="text-xs md:text-sm text-gray-600 mt-1">Bewertung</div>
          </div>
        </div>
      </div>
      <div class="order-1 md:order-2">
        <img src={image} alt="Über uns" class="rounded-2xl shadow-2xl w-full h-64 md:h-[400px] object-cover" loading="lazy" />
      </div>
    </div>
  </div>
</section>
