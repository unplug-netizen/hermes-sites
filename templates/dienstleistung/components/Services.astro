---
export interface Props {
  title: string;
  items: Array<{
    name: string;
    description: string;
    price?: string;
    icon?: string;
    features?: string[];
  }>;
}

const { title, items } = Astro.props;
---

<section id="leistungen" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {items.map((item) => (
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 group">
          <div class="h-40 md:h-48 bg-gradient-to-br from-primary-100 to-emerald-100 flex items-center justify-center relative overflow-hidden">
            <span class="text-5xl md:text-6xl group-hover:scale-110 transition-transform duration-300">{item.icon || '📋'}</span>
          </div>
          <div class="p-5 md:p-6">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-lg md:text-xl font-bold text-gray-900">{item.name}</h3>
              {item.price && (
                <span class="text-primary-600 font-bold text-sm md:text-base whitespace-nowrap ml-2">{item.price}</span>
              )}
            </div>
            <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-4">{item.description}</p>
            {item.features && item.features.length > 0 && (
              <ul class="space-y-1.5">
                {item.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-gray-700">
                    <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            )}
            <a href="#termin" class="mt-5 inline-flex items-center text-primary-600 font-semibold text-sm hover:text-primary-700 transition-colors">
              Termin vereinbaren
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
