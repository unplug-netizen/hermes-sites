---
export interface Props {
  title: string;
  subtitle?: string;
  phone_cta: string;
}

const { title, subtitle, phone_cta } = Astro.props;
---

<section id="termin" class="py-16 md:py-24 bg-slate-900 text-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-10 md:gap-14 items-start">
      
      <!-- Left: Info -->
      <div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
        {subtitle && <p class="text-slate-300 text-lg mb-8 leading-relaxed">{subtitle}</p>}
        
        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold">Kostenloses Erstgespräch</div>
              <div class="text-sm text-slate-400">Ohne Verpflichtung, mit echtem Mehrwert</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold">Transparente Kosten</div>
              <div class="text-sm text-slate-400">Keine versteckten Gebühren</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold">Persönliche Betreuung</div>
              <div class="text-sm text-slate-400">Ein Ansprechpartner für Ihr Anliegen</div>
            </div>
          </div>
        </div>

        <a href={`tel:${phone_cta}`} class="inline-flex items-center gap-3 bg-primary-600 hover:bg-primary-700 text-white font-bold px-8 py-4 rounded-lg text-lg transition-all transform hover:scale-105 shadow-lg shadow-primary-600/25">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {phone_cta}
        </a>
        <p class="mt-3 text-sm text-slate-400">Oder füllen Sie das Formular aus – wir melden uns umgehend</p>
      </div>

      <!-- Right: Form -->
      <div class="bg-white rounded-2xl p-6 md:p-8 text-gray-900">
        <form class="space-y-5" action="#" method="POST" onsubmit="event.preventDefault(); alert('Vielen Dank! Wir melden uns umgehend bei Ihnen.');">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Ihr Name *</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-gray-900" placeholder="Max Mustermann" />
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">E-Mail *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-gray-900" placeholder="max@beispiel.de" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Telefon</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-gray-900" placeholder="030-12345678" />
            </div>
          </div>
          <div>
            <label for="service" class="block text-sm font-semibold text-gray-700 mb-1.5">Gewünschte Beratung</label>
            <select id="service" name="service" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-gray-900 bg-white">
              <option value="">Bitte wählen</option>
              <option value="steuer">Steuerberatung</option>
              <option value="recht">Rechtsberatung</option>
              <option value="unternehmen">Unternehmensberatung</option>
              <option value="finanz">Finanzplanung</option>
              <option value="digital">Digitale Transformation</option>
              <option value="ma">M & A Beratung</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Ihr Anliegen</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none transition-all text-gray-900 resize-none" placeholder="Beschreiben Sie kurz Ihr Anliegen..."></textarea>
          </div>
          <div class="flex items-start gap-2">
            <input type="checkbox" id="privacy" name="privacy" required class="mt-1 w-4 h-4 text-primary-600 rounded border-gray-300 focus:ring-primary-500" />
            <label for="privacy" class="text-xs text-gray-500">Ich stimme der Verarbeitung meiner Daten zu. Ihre Daten werden vertraulich behandelt und nicht an Dritte weitergegeben.</label>
          </div>
          <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 rounded-lg text-lg transition-all transform hover:scale-[1.02] shadow-lg shadow-primary-600/20">
            Termin vereinbaren
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
