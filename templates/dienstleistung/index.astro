---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import TrustBadges from '../components/TrustBadges.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Contact from '../components/Contact.astro';

import siteData from '../data/site.json';
---

<Layout 
  title={`${siteData.business.name} - ${siteData.business.tagline}`}
  description={siteData.content.seo.description}
>
  <Hero 
    title={siteData.content.hero.title}
    subtitle={siteData.content.hero.subtitle}
    cta={siteData.content.hero.cta}
    image={siteData.assets.hero_image}
    badge={siteData.content.hero.badge}
  />
  
  <About 
    title={siteData.content.about.title}
    text={siteData.content.about.text}
    image={siteData.assets.about_image}
  />

  <TrustBadges 
    title={siteData.content.trust.title}
    badges={siteData.content.trust.badges}
  />
  
  <Services 
    title={siteData.content.services.title}
    items={siteData.content.services.items}
  />
  
  <Projects 
    title={siteData.content.projects.title}
    subtitle={siteData.content.projects.subtitle}
    projects={siteData.content.projects.items}
  />

  <ProcessTimeline 
    title={siteData.content.process.title}
    steps={siteData.content.process.steps}
  />

  <TestimonialCarousel 
    title={siteData.content.testimonials.title}
    items={siteData.content.testimonials.items}
  />

  <QuoteForm 
    title={siteData.content.quote.title}
    subtitle={siteData.content.quote.subtitle}
    phone_cta={siteData.content.quote.phone_cta}
  />
  
  <Contact 
    title={siteData.content.contact.title}
    address={siteData.business.address}
    phone={siteData.business.phone}
    hours={siteData.business.hours}
    email={siteData.business.email}
  />
</Layout>
