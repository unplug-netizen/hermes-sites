---
export interface Props {
  title: string;
  steps: Array<{
    number: string;
    title: string;
    text: string;
  }>;
}

const { title, steps } = Astro.props;
---

<section id="prozess" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-20 h-1 bg-primary-600 mx-auto rounded-full"></div>
    </div>

    <div class="relative">
      <!-- Desktop timeline line -->
      <div class="hidden md:block absolute top-12 left-0 right-0 h-0.5 bg-primary-100"></div>

      <div class="grid md:grid-cols-5 gap-8 md:gap-6">
        {steps.map((step, i) => (
          <div class="relative">
            <!-- Step number circle -->
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 md:w-14 md:h-14 bg-primary-600 text-white rounded-full flex items-center justify-center text-lg md:text-xl font-bold shadow-lg shadow-primary-600/20 z-10 relative">
                {step.number}
              </div>
              <div class="mt-4 md:mt-6 text-center">
                <h3 class="text-base md:text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{step.text}</p>
              </div>
            </div>
            <!-- Mobile connector line -->
            {i < steps.length - 1 && (
              <div class="md:hidden absolute left-1/2 -translate-x-1/2 bottom-0 translate-y-full w-0.5 h-8 bg-primary-100"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
