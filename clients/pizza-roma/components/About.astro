---
export interface Props {
  title: string;
  text: string;
  image: string;
}

const { title, text, image } = Astro.props;
---

<section id="ueber-uns" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">{title}</h2>
        <div class="prose prose-lg text-gray-600 leading-relaxed">
          <p>{text}</p>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex -space-x-2">
            {[1,2,3].map(i => (
              <div class="w-10 h-10 rounded-full bg-amber-100 border-2 border-white flex items-center justify-center text-amber-600 text-sm font-bold">
                ★
              </div>
            ))}
          </div>
          <p class="text-sm text-gray-500">Bewertet mit 4.8 von 5 Sternen</p>
        </div>
      </div>
      <div class="order-1 md:order-2">
        <img 
          src={image} 
          alt="Über uns" 
          class="rounded-2xl shadow-2xl w-full h-[400px] object-cover"
        />
      </div>
    </div>
  </div>
</section>