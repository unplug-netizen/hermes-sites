---
export interface Props {
  title: string;
  items: Array<{
    name: string;
    description: string;
    price?: string;
    icon?: string;
  }>;
}

const { title, items } = Astro.props;
---

<section id="leistungen" class="py-20 bg-stone-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-24 h-1 bg-amber-500 mx-auto rounded-full"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      {items.map((item) => (
        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="h-48 bg-gradient-to-br from-amber-100 to-orange-100 flex items-center justify-center">
            <span class="text-5xl">{item.icon || '🔧'}</span>
          </div>
          <div class="p-6">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-xl font-bold text-gray-900">{item.name}</h3>
              {item.price && (
                <span class="text-amber-600 font-bold">{item.price}</span>
              )}
            </div>
            <p class="text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>